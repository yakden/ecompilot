{
  "name": "ecompilot",
  "version": "0.1.0",
  "private": true,
  "description": "EcomPilot PL — SaaS platform for Polish marketplace sellers",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^9.9.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ]
}
