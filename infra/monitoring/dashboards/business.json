      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(subscription_mrr_pln)",
          "instant": true,
          "legendFormat": "MRR",
          "refId": "A"
        }
      ],
      "title": "Monthly Recurring Revenue (PLN)",
      "type": "stat"
