{
  "name": "@ecompilot/analytics-service",
  "version": "0.1.0",
  "private": true,
  "description": "Analytics & reporting service (ClickHouse, marketplace data)",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist .tsbuildinfo"
  },
  "dependencies": {
    "@ecompilot/event-contracts": "workspace:*",
    "@ecompilot/shared-auth": "workspace:*",
    "@ecompilot/shared-observability": "workspace:*",
    "@ecompilot/shared-types": "workspace:*",
    "@clickhouse/client": "^1.8.1",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "bullmq": "^5.16.0",
    "drizzle-orm": "^0.33.0",
    "fastify": "^5.0.0",
    "nats": "^2.28.0",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.0",
    "redis": "^4.7.0",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "playwright": "^1.48.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.24.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
