{
  "name": "@ecompilot/scraper-service",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright headless browser scraper — fallback product data enrichment via Google and Allegro",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist .tsbuildinfo",
    "playwright:install": "npx playwright install chromium"
  },
  "dependencies": {
    "@ecompilot/shared-auth": "workspace:*",
    "@ecompilot/shared-observability": "workspace:*",
    "@ecompilot/shared-types": "workspace:*",
    "fastify": "^5.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "playwright": "^1.48.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
