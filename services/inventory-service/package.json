{
  "name": "@ecompilot/inventory-service",
  "version": "0.1.0",
  "private": true,
  "description": "Inventory management, ABC analysis, and demand forecasting service",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist .tsbuildinfo",
    "db:push": "tsx src/db/push.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@ecompilot/shared-auth": "workspace:*",
    "@ecompilot/shared-observability": "workspace:*",
    "@ecompilot/shared-types": "workspace:*",
    "fastify": "^5.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "decimal.js": "^10.4.3",
    "drizzle-orm": "^0.33.0",
    "nats": "^2.28.2",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
