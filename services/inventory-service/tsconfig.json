{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": ".tsbuildinfo",
    "composite": false,
    "paths": {
      "@ecompilot/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@ecompilot/shared-observability": ["../../packages/shared-observability/src/index.ts"]
    }
  },
  "references": [
    { "path": "../../packages/shared-types" },
    { "path": "../../packages/shared-observability" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
