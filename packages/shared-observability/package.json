{
  "name": "@ecompilot/shared-observability",
  "version": "0.1.0",
  "private": true,
  "description": "OpenTelemetry SDK + Pino logging setup for EcomPilot PL services",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "clean": "rimraf dist .tsbuildinfo",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.49.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.52.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.1",
    "@opentelemetry/instrumentation": "^0.52.1",
    "@opentelemetry/instrumentation-fastify": "^0.38.0",
    "@opentelemetry/instrumentation-http": "^0.52.1",
    "@opentelemetry/instrumentation-pg": "^0.42.0",
    "@opentelemetry/instrumentation-redis-4": "^0.42.0",
    "@opentelemetry/resources": "^1.25.1",
    "@opentelemetry/sdk-metrics": "^1.25.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@opentelemetry/sdk-trace-node": "^1.25.1",
    "@opentelemetry/semantic-conventions": "^1.25.1",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "@ecompilot/shared-types": "workspace:*",
    "@types/node": "^22.5.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4"
  }
}
