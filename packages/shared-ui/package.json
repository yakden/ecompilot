{
  "name": "@ecompilot/shared-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared UI components for EcomPilot PL (React)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "clean": "rimraf dist .tsbuildinfo",
    "lint": "eslint src/**/*.ts"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4"
  }
}
