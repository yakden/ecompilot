{
  "name": "@ecompilot/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "Type-safe API client for EcomPilot PL services",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "clean": "rimraf dist .tsbuildinfo",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "@ecompilot/shared-types": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4"
  }
}
