# ═══════════════════════════════════════════════
# EcomPilot PL — Local Development Environment
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

NODE_ENV=development
LOG_LEVEL=debug

# ── Database ──
DATABASE_URL=postgresql://ecompilot:your_db_password@localhost:5432/ecompilot

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── NATS ──
NATS_URL=nats://localhost:4222

# ── ClickHouse ──
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=ecompilot_analytics
CLICKHOUSE_USER=ecompilot
CLICKHOUSE_PASSWORD=your_clickhouse_password

# ── Elasticsearch ──
ELASTICSEARCH_URL=http://localhost:9200

# ── MinIO / S3 ──
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=ecompilot-media
AWS_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
CDN_URL=http://localhost:9000/ecompilot-media

# ── CloudFront (stub for local) ──
CLOUDFRONT_DOMAIN=localhost
CLOUDFRONT_KEY_PAIR_ID=local-dev
CLOUDFRONT_PRIVATE_KEY=stub-for-local-dev

# ── Auth / JWT ──
# Generate your own RSA key pair:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in private.pem -out public.pem
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
PASTE_YOUR_PRIVATE_KEY_HERE
-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
PASTE_YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"
JWT_SECRET=generate_a_random_64_char_hex_string
ENCRYPTION_KEY=generate_a_random_64_char_hex_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Stripe (test mode) ──
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_MONTHLY_PRICE_ID=price_pro_monthly_id
STRIPE_PRO_YEARLY_PRICE_ID=price_pro_yearly_id
STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_biz_monthly_id
STRIPE_BUSINESS_YEARLY_PRICE_ID=price_biz_yearly_id
APP_URL=http://localhost:3000

# ── OpenAI ──
OPENAI_API_KEY=sk-your-openai-api-key

# ── Pinecone ──
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=ecompilot-knowledge

# ── Resend ──
RESEND_API_KEY=re_your_resend_key

# ── Firebase ──
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=firebase@your-project.iam.gserviceaccount.com

# ── KSeF ──
KSEF_ENVIRONMENT=test
KSEF_NIP=0000000000

# ── Carrier APIs ──
INPOST_API_TOKEN=your-inpost-token
INPOST_ORGANIZATION_ID=your-org-id

# ── Payment Gateways ──
P24_MERCHANT_ID=00000
P24_CRC_KEY=your-p24-crc-key
P24_REPORT_KEY=your-p24-report-key
PAYNOW_API_KEY=your-paynow-key
PAYNOW_SIGNATURE_KEY=your-paynow-sig

# ── PII Encryption ──
PII_ENCRYPTION_KEY=generate_a_random_64_char_hex_string

# ── Service Ports ──
AUTH_SERVICE_PORT=3001
ANALYTICS_SERVICE_PORT=3002
CALC_SERVICE_PORT=3003
AI_SERVICE_PORT=3004
SUPPLIERS_SERVICE_PORT=3005
BILLING_SERVICE_PORT=3006
CONTENT_SERVICE_PORT=3007
LEGAL_SERVICE_PORT=3008
ACADEMY_SERVICE_PORT=3009
COMMUNITY_SERVICE_PORT=3010
NOTIFICATION_SERVICE_PORT=3011
MARKETPLACE_HUB_PORT=3012
LOGISTICS_ENGINE_PORT=3013
KSEF_SERVICE_PORT=3014
PAYMENT_RECONCILIATION_PORT=3015
API_GATEWAY_PORT=3016

# ── Allegro ──
ALLEGRO_CLIENT_ID=your-allegro-client-id
ALLEGRO_CLIENT_SECRET=your-allegro-client-secret
ALLEGRO_REDIRECT_URI=http://localhost:3000/api/auth/allegro/callback

# ── Credentials Encryption ──
CREDENTIALS_ENCRYPTION_KEY=generate_a_random_64_char_hex_string
